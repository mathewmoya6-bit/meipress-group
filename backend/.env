# Server Configuration
PORT=5000
NODE_ENV=production

# Database
DATABASE_URL="mysql://username:password@localhost:3306/mei_group_db"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@meipressgroup.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@meipressgroup.com

# Admin Emails
ADMIN_EMAIL=info@meipressgroup.com
SUPPORT_EMAIL=support@meipressgroup.com

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600

# CORS
CORS_ORIGIN=http://localhost:3000,https://meipressgroup.com
